:root{--bg:#080207;--panel:#130510;--pink:#ff4f9a;--pink2:#ff92c3;--text:#fff8fc;--muted:#d9b8c9;--line:rgba(255,104,168,.4)}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--bg);color:var(--text);font-family:"Noto Sans JP",sans-serif;overflow-x:hidden}.wrap{width:min(1120px,calc(100% - 36px));margin:auto}.sparkles{position:fixed;inset:0;pointer-events:none;z-index:20;opacity:.35;background-image:radial-gradient(circle at 10% 20%,#fff 0 1px,transparent 2px),radial-gradient(circle at 70% 15%,#ff5aa3 0 1px,transparent 2px),radial-gradient(circle at 32% 78%,#fff 0 1px,transparent 2px);background-size:160px 160px,210px 210px,240px 240px;animation:drift 18s linear infinite}@keyframes drift{to{transform:translateY(160px)}}
.hero{position:relative;min-height:760px;display:flex;align-items:center;isolation:isolate}.hero__image{position:absolute;inset:0;background:url('assets/hero.png') center 24%/cover no-repeat;z-index:-3}.hero__shade{position:absolute;inset:0;background:linear-gradient(90deg,rgba(3,0,2,.97) 0%,rgba(5,0,4,.8) 36%,rgba(5,0,4,.18) 66%,rgba(3,0,2,.55) 100%),linear-gradient(0deg,#080207 0%,transparent 28%);z-index:-2}.hero__content{padding:110px 0 95px}.eyebrow,.section-kicker{letter-spacing:.18em;font-weight:700;color:#f7dce8}.hero h1,.section h2,.final-cta h2{font-family:"Shippori Mincho",serif}.hero h1{font-size:clamp(68px,9vw,128px);line-height:.9;margin:14px 0 30px;color:#fff;text-shadow:0 0 6px #fff,0 0 18px var(--pink),0 0 42px #cc145f}.lead{font-size:clamp(21px,2.4vw,31px);line-height:1.7;font-family:"Shippori Mincho",serif}.lead span,em{color:var(--pink2);font-style:normal}.hero__badges{display:flex;gap:12px;margin:36px 0 28px}.hero__badges>div{width:124px;height:124px;border:1px solid var(--line);border-radius:22px;background:rgba(8,2,7,.68);backdrop-filter:blur(10px);display:grid;place-items:center;text-align:center;box-shadow:0 0 20px rgba(255,79,154,.2) inset}.icon{font-size:26px;color:var(--pink2);display:block}.cta{display:inline-flex;align-items:center;justify-content:center;gap:20px;min-width:360px;padding:18px 32px;border-radius:999px;color:white;text-decoration:none;font-weight:800;font-size:21px;background:linear-gradient(180deg,#ff79b5,#df176d);box-shadow:0 0 0 2px #ff9bc6 inset,0 8px 30px rgba(255,39,129,.4);position:relative;overflow:hidden}.cta span{font-size:34px;line-height:1}.shine:before{content:"";position:absolute;top:-50%;left:-40%;width:28%;height:200%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.75),transparent);transform:rotate(18deg);animation:shine 3.5s infinite}@keyframes shine{0%,55%{left:-45%}100%{left:120%}}
.section{padding:92px 0;position:relative}.section--features{background:radial-gradient(circle at 80% 30%,rgba(255,65,144,.16),transparent 28%),linear-gradient(#080207,#120510)}.split{display:grid;grid-template-columns:1.1fr .9fr;gap:34px;align-items:stretch}.feature-card{padding:48px;border:1px solid var(--line);border-radius:28px;background:linear-gradient(145deg,rgba(255,255,255,.055),rgba(255,255,255,.015));box-shadow:0 0 48px rgba(255,47,132,.12)}.section h2{font-size:clamp(34px,4.8vw,58px);line-height:1.28;margin:10px 0 32px}.feature-grid{display:grid;grid-template-columns:repeat(3,1fr);border:1px solid rgba(255,255,255,.12)}.feature-grid div{min-height:118px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;border-right:1px solid rgba(255,255,255,.1);border-bottom:1px solid rgba(255,255,255,.1);text-align:center}.feature-grid b{font-size:32px;color:var(--pink2)}.note{color:var(--muted);line-height:1.8;text-align:center;margin:24px 0 0}.sub-photo{position:relative;border-radius:28px;overflow:hidden;min-height:590px;border:1px solid var(--line)}.sub-photo img{width:100%;height:100%;object-fit:cover;display:block}.sub-photo:after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,rgba(8,2,7,.65),transparent 40%)}.photo-tag{position:absolute;z-index:2;right:20px;bottom:20px;background:#ff4f9a;color:white;padding:10px 18px;border-radius:999px;font-weight:700}
.centered{text-align:center}.bottle-section{background:linear-gradient(180deg,#120510,#050104);overflow:hidden}.bottle-section:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 50% 45%,rgba(255,47,132,.2),transparent 38%)}.bottle-row{display:flex;justify-content:center;align-items:end;gap:18px;margin:56px auto 34px;min-height:440px}.bottle{width:132px;height:390px;border-radius:30px 30px 22px 22px;position:relative;background:linear-gradient(90deg,#1a1a1a,#f8dbe9 22%,#fff 47%,#c4216f 68%,#15040d);box-shadow:0 0 24px rgba(255,62,145,.42);border:2px solid rgba(255,255,255,.35);transform-origin:bottom}.bottle:nth-child(even){height:420px}.bottle:before{content:"";position:absolute;width:46px;height:100px;left:50%;top:-83px;transform:translateX(-50%);border-radius:10px 10px 3px 3px;background:linear-gradient(90deg,#111,#e7b8ce,#111);border:1px solid #ff84b9}.bottle:after{content:"";position:absolute;left:12px;right:12px;top:120px;bottom:34px;border-radius:18px;background-image:url('assets/sub.png');background-size:cover;background-position:center;border:1px solid rgba(255,255,255,.45);filter:saturate(.82) contrast(1.06)}.bottle--1:after{background-position:20% 20%}.bottle--2:after{background-position:45% 20%}.bottle--3:after{background-position:70% 20%}.bottle--4:after{background-position:25% 42%}.bottle--5:after{background-position:55% 42%}.bottle--6:after{background-position:82% 42%}.bottle span{position:absolute;bottom:4px;left:0;right:0;text-align:center;font-size:11px;letter-spacing:.18em;color:#ffb1d2}.caption{text-align:center;color:var(--muted)}
.occasions{background:radial-gradient(circle at 20% 50%,rgba(255,62,145,.13),transparent 35%)}.occasion-grid,.reason-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:44px}.occasion-grid article,.reason-grid>div{padding:32px 24px;border:1px solid var(--line);background:rgba(255,255,255,.025);border-radius:20px;text-align:center}.occasion-grid span,.reason-grid b{font-size:40px}.occasion-grid h3,.reason-grid h3{margin:16px 0 8px}.occasion-grid p,.reason-grid p{color:var(--muted);line-height:1.75;font-size:14px}
.flow{background:#10040d}.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:44px}.steps article{position:relative;padding:42px 28px 34px;border:1px solid var(--line);border-radius:24px;background:linear-gradient(145deg,rgba(255,255,255,.05),rgba(255,255,255,.01));text-align:center}.steps i{position:absolute;top:-18px;left:24px;width:58px;height:58px;border-radius:50%;display:grid;place-items:center;background:var(--pink);font-weight:900;font-style:normal}.steps span{font-size:46px}.steps p{color:var(--muted);line-height:1.7}.reasons{background:linear-gradient(#10040d,#080207)}
.faq{padding-top:65px}.accordion{max-width:860px;margin:38px auto 0}.accordion details{border-bottom:1px solid rgba(255,255,255,.16);padding:0}.accordion summary{cursor:pointer;list-style:none;padding:22px 8px;font-weight:700;font-size:18px}.accordion summary:after{content:"＋";float:right;color:var(--pink2)}.accordion details[open] summary:after{content:"－"}.accordion p{color:var(--muted);line-height:1.8;padding:0 8px 22px;margin:0}
.final-cta{position:relative;padding:120px 0;text-align:center;isolation:isolate;overflow:hidden}.final-cta__bg{position:absolute;inset:0;background:linear-gradient(rgba(8,2,7,.62),rgba(8,2,7,.92)),url('assets/hero.png') center 35%/cover;z-index:-1}.final-cta p{font-family:"Shippori Mincho",serif;font-size:19px}.final-cta h2{font-size:clamp(38px,6vw,68px);color:#ff9cc6;text-shadow:0 0 20px rgba(255,48,137,.7)}footer{text-align:center;padding:24px;color:#876879;background:#040103}.floating-cta{display:none}
.reveal{opacity:0;transform:translateY(24px);transition:.75s ease}.reveal.visible{opacity:1;transform:none}
@media(max-width:850px){.hero{min-height:820px;align-items:end}.hero__image{background-position:58% top}.hero__shade{background:linear-gradient(0deg,#080207 0%,rgba(8,2,7,.82) 48%,rgba(8,2,7,.12) 88%)}.hero__content{padding:300px 0 80px}.hero h1{font-size:70px}.lead{font-size:20px}.hero__badges{gap:8px}.hero__badges>div{width:105px;height:105px;font-size:13px}.cta{min-width:100%;font-size:18px}.split{grid-template-columns:1fr}.sub-photo{min-height:500px}.bottle-row{overflow-x:auto;justify-content:flex-start;padding:90px 10px 10px;scroll-snap-type:x mandatory}.bottle{flex:0 0 110px;height:340px;scroll-snap-align:center}.bottle:nth-child(even){height:370px}.occasion-grid,.reason-grid{grid-template-columns:repeat(2,1fr)}.steps{grid-template-columns:1fr}.floating-cta{display:block;position:fixed;right:14px;bottom:14px;z-index:50;background:linear-gradient(#ff78b2,#d70c62);color:#fff;text-decoration:none;font-weight:800;padding:14px 22px;border-radius:999px;box-shadow:0 5px 25px rgba(255,29,123,.5)}}
@media(max-width:560px){.wrap{width:min(100% - 24px,1120px)}.section{padding:70px 0}.feature-card{padding:28px 16px}.feature-grid{grid-template-columns:repeat(2,1fr)}.sub-photo{min-height:430px}.occasion-grid,.reason-grid{grid-template-columns:1fr 1fr}.occasion-grid article,.reason-grid>div{padding:24px 14px}.hero__badges>div{width:calc((100vw - 48px)/3)}.final-cta{padding:90px 0}}
